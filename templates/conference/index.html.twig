{% extends 'base.html.twig' %}

{% block title %} Conference Guestbook! {% endblock %}

{% block body %}
    <h2>Give your feedback!</h2>

    {% for conference in conferences %}
        <p>
            <a href="{{ path('conference', { id: conference.id }) }}">{{ conference.city }}</a>
        </p>
    {% endfor %}

{% endblock %}
